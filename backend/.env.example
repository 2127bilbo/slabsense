# SlabSense Backend Environment Variables
# Copy to .env and fill in values

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# CORS - Frontend URLs allowed to access API
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://slabsense.vercel.app

# Supabase (for auth verification)
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Image Processing
MAX_IMAGE_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30

# Redis (for production queue - Stage 2)
# REDIS_URL=redis://localhost:6379

# Replicate AI (for card detection)
# Get token at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your_token_here
